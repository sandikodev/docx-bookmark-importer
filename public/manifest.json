{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.0.0",
  "description": "__MSG_appDescription__",
  "default_locale": "en",
  "action": {
    "default_popup": "index.html",
    "default_icon": "favicon.svg"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "48": "favicon.svg",
    "128": "favicon.svg"
  },
  "permissions": [
    "bookmarks",
    "storage",
    "sidePanel",
    "contextMenus"
  ],
  "background": {
    "service_worker": "background.js"
  }
}

